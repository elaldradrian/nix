{
  "mcpServers": {
    "vectorcode": {
      "command": "vectorcode-mcp-server",
      "args": []
    },
    "fetch": {
      "args": ["run", "-i", "--rm", "mcp/fetch"],
      "command": "docker"
    },
    "git": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--mount",
        "type=bind,src=${REPOSITORY_PATH},dst=/workspace",
        "mcp/git"
      ]
    },
    "effect-docs": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "timsmart/effect-mcp"]
    },
    "memory": {
      "command": "docker",
      "args": ["run", "--rm", "-i", "-v", "mcp-memory:/app/dist", "mcp/memory"]
    }
  }
}
